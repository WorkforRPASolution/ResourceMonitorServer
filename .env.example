# ResourceMonitorServer — 로컬 개발용 환경 변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env 로 복사:      cp .env.example .env
#   2. 필요하면 값 수정. 기본값(OrbStack/localhost)으로 대부분 그대로 동작.
#   3. .env 는 절대 커밋 금지 (.gitignore 에 등록됨).
#
# ─── 경고 ─────────────────────────────────────────────────────────────
# 이 파일에는 production 주소/credential 을 절대 적지 마세요.
# Production 환경은 K8s Secret/ConfigMap 으로만 관리되며, 개발 PC 의
# 어떤 env 파일에도 존재해선 안 됩니다. 자세한 이유는 SECURITY.md 또는
# CONTRIBUTING.md 의 "환경 분리" 섹션 참고.
# ──────────────────────────────────────────────────────────────────────

# ---------- MongoDB (OrbStack: mongodb-44) ----------
MONITOR_MONGO_URI=mongodb://localhost:27017
# prod 와 다른 DB 이름 사용 — 실수로 prod 컬렉션을 건드릴 수 없게 격리
MONITOR_MONGO_DB=EARS_dev

# ---------- Elasticsearch (make dev-up) ----------
# 콤마 구분 또는 JSON 배열 모두 허용 — parse_es_hosts validator 참고
MONITOR_ES_HOSTS=http://localhost:9200
MONITOR_ES_USERNAME=
MONITOR_ES_PASSWORD=
MONITOR_ES_USE_SSL=false
MONITOR_ES_REQUEST_TIMEOUT=30
MONITOR_ES_MAX_RETRIES=3

# ---------- Zookeeper (make dev-up) ----------
MONITOR_ZK_HOSTS=localhost:2181
# prod 와 다른 루트 경로 — 같은 ZK 를 공유해도 파티션이 분리됨
MONITOR_ZK_ROOT_PATH=/resource-monitor-dev
MONITOR_ZK_SESSION_TIMEOUT=30
MONITOR_ZK_SASL_MECHANISM=
MONITOR_ZK_SASL_USERNAME=
MONITOR_ZK_SASL_PASSWORD=

# ---------- Redis (make dev-up — Redis 5.0.6) ----------
# DB 5 = RMS 전용 (0=WebManager, 10=socks/direct-agent, 15=integration 테스트).
# prod k8s/configmap.yaml 와 동일한 DB 번호를 사용해 DB 선택 관련 버그를
# 로컬에서도 조기에 잡는다.
MONITOR_REDIS_URL=redis://localhost:6379/5
MONITOR_REDIS_PASSWORD=
# prod 와 다른 키 prefix — 같은 Redis 를 공유해도 네임스페이스 분리
MONITOR_REDIS_KEY_PREFIX=RESOURCE_ALERT_dev

# ---------- Email API ----------
# 로컬 실행 시에는 실제 Akka 서버 대신 목업 서버 띄워서 사용 권장.
# 테스트는 pytest 픽스처가 in-process aiohttp mock 서버를 띄움.
MONITOR_EMAIL_API_URL=http://localhost:18080/EmailNotify
MONITOR_EMAIL_API_TIMEOUT=10
# Akka EMAIL_TEMPLATE / EMAIL_CATEGORY 조회 키 (PRD §8.1 필수 필드).
# 운영 EARS 환경에서는 "ARS" 사용. 별도 app 키 운용 시 override.
MONITOR_EMAIL_APP_NAME=ARS

# ---------- Grafana (알림 본문 링크) ----------
MONITOR_GRAFANA_BASE_URL=http://localhost:3000
MONITOR_GRAFANA_DASHBOARD_UID=

# ---------- Scheduler / Instance ----------
MONITOR_SCHEDULER_MISFIRE_GRACE_TIME=60
MONITOR_INSTANCE_ID=dev-local
MONITOR_LOCAL_TZ=Asia/Seoul

# ---------- Logging ----------
MONITOR_LOG_LEVEL=INFO
# console 은 사람이 읽기 편함. prod 는 json.
MONITOR_LOG_FORMAT=console

# ---------- Debug Mode (선택) ----------
# true 로 설정하면 쓰기 경로 전부 차단됨 (schema 변경/seed/ZK 참여/email 발송/Redis cooldown).
# scheduler 는 정상 동작하며 분석 결과는 stdout 에 로그만 남김.
# "prod 데이터를 읽으면서 분석 흐름 관찰" 용도. 절대 production K8s 에 넣지 말 것.
# 자세한 동작은 CONTRIBUTING.md 의 "Debug Read-Only 모드" 참고.
#MONITOR_DEBUG_READ_ONLY=false
# debug 모드에서 분석 대상 process 를 명시적으로 지정. 비어있으면
# get_distinct_processes() 결과 전체를 사용.
#MONITOR_DEBUG_PROCESSES=ETCH,CVD
