# ----------------------------------------------------------------------
# мҡҙмҳҒ л°°нҸ¬ м „ placeholderлҘј мӢӨм ң к°’мңјлЎң мұ„мӣҢ лі„лҸ„ secret.yamlлЎң м ҖмһҘ нӣ„
# kubectl apply. мқҙ .example нҢҢмқјмқҖ м»Өл°Ӣн•ҳлҗҳ, secret.yamlмқҖ .gitignore.
# ----------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: resource-monitor-secrets
  labels:
    app: resource-monitor-server
type: Opaque
stringData:
  # Mongo мһҗкІ©мҰқлӘ… вҖ” URIм—җ user:password нҸ¬н•Ё
  MONITOR_MONGO_URI: "mongodb://USER:CHANGE_ME@mongodb.ears:27017"

  # ES basic auth password
  MONITOR_ES_PASSWORD: "CHANGE_ME"

  # Redis AUTH (5.0.6мқҖ ACL м—ҶмқҢ вҖ” лӢЁмқј password)
  MONITOR_REDIS_PASSWORD: "CHANGE_ME"

  # ZK SASL вҖ” лҜёмӮ¬мҡ© мӢң л‘ҳ лӢӨ л№Ҳ л¬ёмһҗм—ҙ
  MONITOR_ZK_SASL_MECHANISM: ""
  MONITOR_ZK_SASL_USERNAME: ""
  MONITOR_ZK_SASL_PASSWORD: ""
